# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=BusinessPilot AI
# Options: development | staging | production
ENVIRONMENT=development
# Set to false in production
DEBUG=true
API_V1_PREFIX=/api/v1
FRONTEND_ORIGIN=http://localhost:3000

# ─── Security ────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
# Fernet key — encrypts Google OAuth tokens stored in the DB.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-fernet-key

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite for local dev. Swap to postgresql+asyncpg://user:pass@host:5432/dbname for production.
DATABASE_URL=sqlite+aiosqlite:///./storage/businesspilot.db

# ─── Qwen / DashScope ────────────────────────────────────────────────────────
QWEN_API_KEY=sk-your-dashscope-api-key
# International workspace endpoints (replace with China region URLs if needed):
#   https://dashscope.aliyuncs.com/api/v1  (China)
#   https://dashscope-intl.aliyuncs.com/api/v1  (International)
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
DASHSCOPE_COMPAT_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Models confirmed available on the DashScope international workspace:
QWEN_CHAT_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v3
# Note: STT/TTS are handled by the browser (Web Speech API). No server-side ASR/TTS is used.

# ─── Google OAuth (Gmail + Calendar) ─────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI must include: http://localhost:8000/api/v1/integrations/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/integrations/google/callback

# ─── Storage ─────────────────────────────────────────────────────────────────
STORAGE_DIR=./storage/documents
